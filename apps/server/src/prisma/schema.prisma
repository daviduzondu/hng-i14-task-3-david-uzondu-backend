generator kysely {
    provider = "prisma-kysely"
    output   = "../db/generated"
    fileName = "types.ts"
}

datasource db {
    provider = "postgresql"
}

model users {
    id            String   @id @unique @default(dbgenerated("gen_random_uuid()"))
    github_id     String   @unique
    username      String
    email         String
    avatar_url    String
    role          Role @default(analyst)
    is_active     Boolean
    last_login_at DateTime @db.Timestamptz()
    created_at    DateTime @default(now()) @db.Timestamptz()
    updated_at    DateTime @default(now()) @db.Timestamptz()
}

model profiles {
    id                  String   @id @unique @default(dbgenerated("gen_random_uuid()"))
    name                String
    gender              Gender
    gender_probability  Float
    age                 Int
    age_group           AgeGroup
    country_id          String
    country_probability Float
    country_name        String
    created_at          DateTime @default(now()) @db.Timestamptz()
    updated_at          DateTime @default(now()) @db.Timestamptz()
}

enum Role {
    admin
    analyst
}

enum Gender {
    female
    male
}

enum AgeGroup {
    child
    teenager
    adult
    senior
}
