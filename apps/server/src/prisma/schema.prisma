generator kysely {
 provider = "prisma-kysely"
 output   = "../db/generated"
 fileName = "types.ts"
}

datasource db {
 provider = "postgresql"
}

model profile {
 id                  String   @id @unique @default(dbgenerated("gen_random_uuid()"))
 name                String
 gender              Gender
 gender_probability  Float
 age                 Int
 age_group           AgeGroup
 country_id          String
 country_probability Float
 country_name        String
 created_at          DateTime @default(now()) @db.Timestamptz()
 updated_at          DateTime @default(now()) @db.Timestamptz()
}

enum Gender {
 female
 male
}

enum AgeGroup {
 child
 teenager
 adult
 senior
}
